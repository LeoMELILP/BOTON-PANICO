##############################################################################
##
##  Gradle start up script for UN*X
##
##############################################################################

PRG="$0"
while [ -h "$PRG" ] ; do
    ls -l "$PRG" | grep " -> " | sed 's/.*-> \(.*\)/\1/' > /dev/null
    if [ $? -eq 0 ]; then
	PRG=`ls -l "$PRG" | grep " -> " | sed 's/.*-> \(.*\)/\1/'`
    else
	break
    fi
done

if [ -z "$DIRNAME" ] ; then
  DIRNAME=`dirname "$PRG"`
  cd "$DIRNAME"
  DIRNAME=`pwd`
  cd "$OLDPWD"
fi

if [ ! -f "$DIRNAME/gradle/wrapper/gradle-wrapper.jar" ] ; then
    echo "Gradle wrapper not found. Please ensure gradle wrapper is properly installed."
    exit 1
fi

DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

CLASSPATH=$DIRNAME/gradle/wrapper/gradle-wrapper.jar

exec java $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS \
  -classpath "$CLASSPATH" \
  org.gradle.wrapper.GradleWrapperMain "$@"
