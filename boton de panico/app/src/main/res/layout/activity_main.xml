<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginBottom="40dp">

        <Button
            android:id="@+id/panic_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Botón de\nPánico"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@android:color/holo_red_dark"
            android:elevation="8dp"
            android:layout_margin="4dp"
            android:contentDescription="Botón de pánico para compartir ubicación" />

    </FrameLayout>

    <Button
        android:id="@+id/contacts_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Configurar Contactos de Emergencia"
        android:textSize="16sp"
        android:layout_marginBottom="10dp"
        android:backgroundTint="@android:color/holo_blue_dark" />

    <Button
        android:id="@+id/status_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Ver Estado de Compartir"
        android:textSize="16sp"
        android:backgroundTint="@android:color/holo_green_dark" />

</LinearLayout>
